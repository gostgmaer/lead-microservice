# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4003
APP_NAME=lead-microservice
APP_VERSION=1.0.0

# ─── Database ───────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/lead_microservice

# ─── Contact / Lead Microservice ────────────────────────────
EMAIL_SERVICE_URL=http://localhost:3100        # Base URL of the Email Microservice (no trailing slash)
EMAIL_SERVICE_API_KEY=your-api-key-here       # Bearer token for Email Microservice authentication
ADMIN_EMAIL=admin@yourcompany.com             # Recipient of LEAD_ADMIN_NOTIFICATION emails
DASHBOARD_URL=http://localhost:3000           # Frontend dashboard URL (used in review links)
LEAD_FILE_MAX_SIZE_MB=10                      # Max single file size in MB (default: 10)
LEAD_FILE_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,png,jpg,jpeg,gif,zip,csv
LEAD_PIPELINE_STAGES=New,Contacted,Qualified,Proposal Sent,Negotiation,Won,Lost,Archived
AUTH_SERVICE_URL=http://localhost:4002        # Base URL of the user-auth-service (no trailing slash)

# ─── IAM JWT verification (local, platform convention) ──────
# Tokens are verified locally, not via AUTH_SERVICE_URL: RS256 with IAM's
# public key (raw PEM or base64-encoded PEM), HS256 shared secret as the
# transition fallback. Copy the same values every other product service uses.
JWT_PUBLIC_KEY=                               # IAM RS256 public key (PEM or base64 PEM)
JWT_SECRET=                                   # HS256 fallback shared secret
JWT_ISSUER=                                   # e.g. easydev-iam
JWT_AUDIENCE=                                 # e.g. easydev

# ─── CORS ───────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Redis (optional — set REDIS_ENABLED=true to activate) ────────────────────
# When enabled, provides cross-instance rate limiting and distributed cron locks.
# Both REDIS_ENABLED=true AND a valid REDIS_URL are required to use Redis.
# If either is missing or REDIS_ENABLED=false, the service falls back to in-memory.
REDIS_ENABLED=false
# REDIS_URL=redis://localhost:6379
# REDIS_URL=rediss://user:password@your-redis-host:6380  (TLS)
# --- Tenant configuration ---
# Enforce tenant scoping on every request.
# true  → resolve tenant from x-tenant-id (fallback DEFAULT_TENANT_ID=easydev).
# false → do not resolve/check tenant; ignore x-tenant-id even if provided.
TENANCY_ENABLED=true
# Fallback tenant when x-tenant-id header is absent.
# For single-tenant: set to your slug. For strict enforcement: leave blank.
DEFAULT_TENANT_ID=easydev
